# -----------------------------------------------------------------------------
# Telegram — Alertas (herdado do bot_taxa_cripto)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
POLL_INTERVAL_SECONDS=3
START_FROM_LATEST=true
RECONNECT_DELAY_SECONDS=5
FILTER_USER_IDS=
TELEGRAM_PARSE_MODE=HTML

# -----------------------------------------------------------------------------
# Coinalyze — Métricas avançadas (herdado do bot_taxa_cripto)
# -----------------------------------------------------------------------------
COINALYZE_API_KEY=
COINALYZE_BASE_URL=https://api.coinalyze.net/v1
COINALYZE_TIMEOUT=20
COINALYZE_DEFAULT_SYMBOLS=6
COINALYZE_MAX_SYMBOLS=8
COINALYZE_SERVICE_URL=http://coinalyze-metrics:8010

# -----------------------------------------------------------------------------
# Serviços internos (portas Docker)
# -----------------------------------------------------------------------------
RUST_CORE_PORT=8001
PYTHON_API_PORT=8000
SCRAPER_PORT=8002

# -----------------------------------------------------------------------------
# Configurações padrão do bot (sobrescrevíveis via API)
# -----------------------------------------------------------------------------
DEFAULT_LEVERAGE=5
DEFAULT_MAX_POSITIONS=5
DEFAULT_MIN_SCORE=65

# -----------------------------------------------------------------------------
# Frontend (herdado do bot_taxa_cripto — dev local)
# -----------------------------------------------------------------------------
VITE_DEV_TEST_USER=true
VITE_DEV_TEST_EMAIL=dev@local.test
VITE_API_BASE_URL=http://localhost:8000
