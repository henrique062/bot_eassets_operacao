# ============================================================
# rust_core — variáveis de ambiente
# Copie para .env e preencha com os valores reais
# ============================================================

# --- Banco de dados PostgreSQL ---
DATABASE_URL=postgres://user:password@localhost:5432/encryptos_db

# --- Bybit API (produção) ---
BYBIT_API_KEY=sua_api_key_aqui
BYBIT_API_SECRET=seu_api_secret_aqui

# --- Símbolos monitorados (separados por vírgula) ---
BYBIT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT

# --- Servidor Axum ---
RUST_CORE_PORT=8001

# --- URL do serviço Python para notificações internas ---
PYTHON_API_URL=http://python_api:8000

# --- Identificação da configuração no banco ---
BOT_CONFIG_ID=1
BOT_CONFIG_NAME=encryptos_default

# --- Parâmetros de capital e risco ---
CAPITAL_PER_TRADE=100.0
LEVERAGE=10
MAX_POSITIONS=3
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0
TRAILING_STOP_PCT=1.5
TRAILING_START_PCT=2.0

# --- Filtros de entrada ---
MIN_TPM=800.0
MAX_LSR=1.0
MAX_RSI_BTC=40.0
MIN_SCORE=60.0

# --- PCL (Position-Cooldown-Loop) ---
PCL_ENABLED=true
PCL_COOLDOWN_MINUTES=30
PCL_MAX_ATTEMPTS=3
PCL_MIN_STRUCT_SCORE=3

# --- Logging ---
# Níveis: trace, debug, info, warn, error
RUST_LOG=info
