# =============================================================================
# PHOENIX Bot — Environment Variables
# Copy this file to .env and fill in the values before running docker-compose.
# NEVER commit the .env file to version control.
# =============================================================================

# --- PostgreSQL ---
DATABASE_URL=postgresql://encryptos:changeme@db:5432/encryptos
POSTGRES_USER=encryptos
POSTGRES_PASSWORD=changeme
POSTGRES_DB=encryptos
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Bybit API ---
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_BASE_URL=https://api.bybit.com

# --- Bybit symbols monitored ---
BYBIT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,DOTUSDT,LINKUSDT

# --- eAssets scraper ---
EASSETS_EMAIL=
EASSETS_PASSWORD=
EASSETS_INTERVAL_SECONDS=1800
EASSETS_AUTO_ENABLED=1
EASSETS_HEADLESS=1
EASSETS_TIMEOUT_MS=120000

# --- Gemini AI ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=HTML

# --- Coinalyze ---
COINALYZE_API_KEY=
COINALYZE_BASE_URL=https://api.coinalyze.net
COINALYZE_SERVICE_URL=http://coinalyze_service:8003

# --- Internal ports ---
RUST_CORE_PORT=8001
PYTHON_API_PORT=8000
SCRAPER_PORT=8002
RUST_CORE_URL=http://rust_core:8001

# --- Bot defaults ---
DEFAULT_LEVERAGE=5
DEFAULT_MAX_POSITIONS=5
DEFAULT_MIN_SCORE=65.0
